{
    "name": "bycerfrance/llm-api-lib",
    "description": "PHP library for interacting with multiple LLM providers (Google, Mistral, OpenAI, OVH and any OpenAI-compatible endpoint) with failover, retry, and tool calling support",
    "keywords": ["llm", "ai", "api", "openai", "mistral", "google", "ovh", "chat", "function-calling", "tools"],
    "license": "MIT",
    "type": "library",
    "homepage": "https://www.vigicorp.fr",
    "support": {
        "issues": "https://github.com/ByCerfrance/LlmApiLib/issues",
        "source": "https://github.com/ByCerfrance/LlmApiLib"
    },
    "authors": [
        {
            "name": "Vigicorp",
            "homepage": "https://www.vigicorp.fr"
        }
    ],
    "autoload": {
        "psr-4": {
            "ByCerfrance\\LlmApiLib\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ByCerfrance\\LlmApiLib\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.3",
        "berlioz/http-message": "^2.5 || ^3.0",
        "psr/http-client": "^1.0",
        "psr/http-message": "^2.0"
    },
    "require-dev": {
        "ext-curl": "*",
        "ext-fileinfo": "*",
        "ext-gd": "*",
        "berlioz/http-client": "^2.3 || ^3.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^12.0",
        "devizzent/cebe-php-openapi": "^1.1"
    },
    "suggest": {
        "ext-fileinfo": "To create content from file or stream",
        "devizzent/cebe-php-openapi": "Required to use the OpenApi class for OpenAPI spec parsing (3.0 and 3.1)"
    },
    "scripts": {
        "test": "vendor/bin/phpunit --colors=never --stderr",
        "analyse": "vendor/bin/phpstan analyse src tests"
    }
}
